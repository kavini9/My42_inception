# Copy this file to .env and replace all change_me_* values before running.

# Domain used by NGINX server_name and WordPress URLs
DOMAIN_NAME=yourlogin.42.fr

# MariaDB bootstrap settings
MYSQL_DATABASE=wordpress
MYSQL_USER=wpuser
MYSQL_PASSWORD=change_me_wp_password
MYSQL_ROOT_PASSWORD=change_me_root_password

# WordPress bootstrap settings
WP_TITLE=Inception Site
WP_ADMIN_USER=siteowner
WP_ADMIN_PASSWORD=change_me_admin_password
WP_ADMIN_EMAIL=you@example.com
WP_USER=user42
WP_USER_EMAIL=user42@example.com
WP_USER_PASSWORD=change_me_user_password
